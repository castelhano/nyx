// Role global do usuário no sistema
enum UserRole {
  admin    // acesso total, bypass de filtros por filial
  operator // deny-all rquer permissao nos recursos
}

// Role do usuário dentro de uma filial específica, nao influencia logica de
// permissoes neste momento, apenas label referencial
enum BranchUserRole {
  owner   // responde pela filial
  manager // tem cargo gerencial na filial
  member  // funcionario da filial
}

model User {
  id           String    @id @default(uuid())
  name         String
  username     String    @unique
  email        String?   @unique
  passwordHash String
  role         UserRole  @default(operator)
  preferences  Json?     // { theme, language, sidebar, notifications, ... }
  lastLoginAt  DateTime?
  isActive              Boolean   @default(true)
  forcePasswordChange   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branches        UserBranch[]
  permissions     UserPermission[]
  passwordHistory UserPasswordHistory[]

  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  legalName String
  tradeName String?
  taxId     String   @unique // CNPJ da matriz
  phone     String?
  email     String?
  website   String?
  address   String?
  city      String?
  state     String?  // UF — 2 chars
  zipCode   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]

  @@map("companies")
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  name      String   // ex: "Filial São Paulo", "CD Sul"
  taxId     String?  @unique // CNPJ da filial (opcional — pode usar o da matriz)
  phone     String?
  email     String?
  address   String?
  city      String?
  state     String?  // UF — 2 chars
  zipCode   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  users      UserBranch[]
  employees  Employee[]
  vehicles   Vehicle[]

  transitLines      TransitLine[]      @relation("BranchTransitLines")
  travelTimes       TravelTimeMatrix[] @relation("BranchTravelTimes")
  depotFleets       DepotFleet[]       @relation("BranchDepotFleets")
servicePeriods    ServicePeriod[]    @relation("BranchServicePeriods")
  transitTrips      TransitTrip[]      @relation("BranchTransitTrips")
  vehiclePlans      VehiclePlan[]      @relation("BranchVehiclePlans")

  @@map("branches")
}

// Associação usuário ↔ filial com role por filial
model UserBranch {
  id        String         @id @default(uuid())
  userId    String
  branchId  String
  role      BranchUserRole @default(member)
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@map("user_branches")
}

// Permissões explícitas por usuário (sobrescrevem/estendem o role global)
model UserPermission {
  id        String   @id @default(uuid())
  userId    String
  resource  String   // 'User', 'Company', 'Branch', etc.
  action    String   // 'create', 'read', 'update', 'delete'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource, action])
  @@map("user_permissions")
}

// Histórico de senhas para evitar reutilização
model UserPasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_password_history")
}

// Configurações do app
model Settings {
  key       String
  scope     String   @default("global") // 'global' | branchId
  value     Json
  updatedAt DateTime @updatedAt

  @@id([key, scope])
  @@map("settings")
}
