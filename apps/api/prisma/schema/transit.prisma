enum LineType {
  URBAN
  METROPOLITAN
  RURAL
  SPECIAL
}

enum RouteDirection {
  OUTBOUND
  INBOUND
  CIRCULAR
}

enum TravelTimeSource {
  OSRM
  MANUAL
}

enum VehiclePlanStatus {
  DRAFT
  ACTIVE
}

enum DeadrunType {
  ACCESS
  RETURN
  DISPLACEMENT

  @@map("transit_deadrun_type")
}

model TransitLocality {
  id        String   @id @default(uuid())
  code      String   @unique
  abbr      String?
  name      String
  lat       Float?
  lng       Float?
  isDepot   Boolean  @default(false)
  notes     String?
  snapInfo  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  travelTimesFrom      TravelTimeMatrix[] @relation("TravelTimeOrigin")
  travelTimesTo        TravelTimeMatrix[] @relation("TravelTimeDestination")
  routesAsOrigin       TransitRoute[]     @relation("RouteOrigin")
  routesAsDestination  TransitRoute[]     @relation("RouteDestination")
  routeLocalities      RouteLocality[]
  vehicleBlocks        VehicleBlock[]
  deadrunsAsOrigin     BlockDeadrun[]     @relation("DeadrunOrigin")
  deadrunsAsDestination BlockDeadrun[]    @relation("DeadrunDestination")

  @@map("transit_localities")
}

model TransitLine {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  type      LineType
  isActive  Boolean  @default(true)
  notes     String?
  /* metrics shape
   {
   "extensionKm":{"OUTBOUND":16.5,"INBOUND":16.5},
   "windows":{
      "OUTBOUND":[{"from":4,"to":5,"minutes":54,"intervalMinutes":10}, ...
   "demand":{
      "U":{
          "OUTBOUND":{
              "4":24,"5":241,...
  */
  metrics   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routes     TransitRoute[]
  planLines  VehiclePlanLine[]
  exceptions LineCalendarExceptionLine[]
  lineGroups LineGroupLine[]

  @@map("transit_lines")
}

model TransitRoute {
  id                    String         @id @default(uuid())
  lineId                String
  direction             RouteDirection
  name                  String
  originLocalityId      String
  destinationLocalityId String
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  line                TransitLine     @relation(fields: [lineId], references: [id])
  originLocality      TransitLocality @relation("RouteOrigin", fields: [originLocalityId], references: [id])
  destinationLocality TransitLocality @relation("RouteDestination", fields: [destinationLocalityId], references: [id])
  localities          RouteLocality[]
  trips               TransitTrip[]

  @@map("transit_routes")
}

model RouteLocality {
  id               String           @id @default(uuid())
  routeId          String
  // null = routing waypoint (forces OSRM through a point without being a bus stop)
  localityId       String?
  // populated when localityId is null (waypoint coords)
  lat              Float?
  lng              Float?
  sequence         Int
  // null → runtime falls back to TravelTimeMatrix for this pair
  deltaMinutes     Int?
  deltaKm          Float?
  // protects manual overrides from being clobbered by auto-generation
  deltaSource      TravelTimeSource @default(OSRM)
  // GeoJSON LineString for the leg from the previous stop to this one; null for sequence=1
  geometry         Json?
  allowsCrewChange Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  route    TransitRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  // nulls are treated as distinct in both SQLite and PG — multiple waypoints per route are allowed
  locality TransitLocality? @relation(fields: [localityId], references: [id])

  @@unique([routeId, sequence])
  @@unique([routeId, localityId])
  @@map("transit_route_localities")
}

model TravelTimeMatrix {
  id             String           @id @default(uuid())
  originId       String
  destinationId  String
  baseMinutes    Float
  distanceKm     Float
  // multiplier applied to baseMinutes by the solver (e.g. > 1 for bottlenecks/construction)
  speedRatio     Float            @default(1.0)
  source         TravelTimeSource @default(MANUAL)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  origin      TransitLocality @relation("TravelTimeOrigin", fields: [originId], references: [id])
  destination TransitLocality @relation("TravelTimeDestination", fields: [destinationId], references: [id])

  @@unique([originId, destinationId])
  @@map("transit_travel_times")
}

model DayType {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  pattern     Json?
  priority    Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trips                        TransitTrip[]
  vehiclePlans                 VehiclePlan[]
  calendarExceptionsAsOverride LineCalendarException[] @relation("ExceptionOverrideDayType")
  calendarExceptionsAsSource   LineCalendarException[] @relation("ExceptionSourceDayType")

  @@map("transit_day_types")
}

model LineCalendarException {
  id                String    @id @default(uuid())
  validFrom         DateTime
  validTo           DateTime?
  sourceDayTypeId   String?
  overrideDayTypeId String
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sourceDayType   DayType?                   @relation("ExceptionSourceDayType", fields: [sourceDayTypeId], references: [id])
  overrideDayType DayType                    @relation("ExceptionOverrideDayType", fields: [overrideDayTypeId], references: [id])
  lines           LineCalendarExceptionLine[]

  @@map("transit_line_calendar_exceptions")
}

model LineCalendarExceptionLine {
  exceptionId String
  lineId      String

  exception LineCalendarException @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  line      TransitLine           @relation(fields: [lineId], references: [id])

  @@id([exceptionId, lineId])
  @@map("transit_line_calendar_exception_lines")
}

model TransitTrip {
  id                  String       @id @default(uuid())
  routeId             String
  dayTypeId           String
  // minutes from operational day start; values > 1440 indicate overnight trips
  departureMinutes    Int
  arrivalMinutes      Int
  requiredVehicleType VehicleType?
  // {"locked":["departureMinutes","cycleTime"]}
  constraints         Json?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  route      TransitRoute @relation(fields: [routeId], references: [id])
  dayType    DayType      @relation(fields: [dayTypeId], references: [id])
  blockTrips BlockTrip[]

  @@map("transit_trips")
}

model VehiclePlan {
  id          String            @id @default(uuid())
  dayTypeId   String
  description String?
  status      VehiclePlanStatus @default(DRAFT)
  // populated by solver, current shape:
  // {"fleetCount":102,"score":0,"deadrunKm":0,"productiveKm":23249.58,"totalKm":23249.58,"deadrunMinutes":6650,"productiveMinutes":73213,"totalMinutes":98230}
  summary     Json?
  generatedAt DateTime?
  // { locked?: true }
  constraints Json?
  metrics     Json?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  dayType DayType           @relation(fields: [dayTypeId], references: [id])
  lines   VehiclePlanLine[]
  blocks  VehicleBlock[]

  @@map("transit_vehicle_plans")
}

model VehiclePlanLine {
  vehiclePlanId String
  lineId        String

  vehiclePlan VehiclePlan @relation(fields: [vehiclePlanId], references: [id], onDelete: Cascade)
  line        TransitLine @relation(fields: [lineId], references: [id])

  @@id([vehiclePlanId, lineId])
  @@map("transit_vehicle_plan_lines")
}

model VehicleBlock {
  id            String      @id @default(uuid())
  vehiclePlanId String
  branchId      String?
  blockNumber   Int
  depotId       String
  vehicleType VehicleType
  // true when any trip in the block was modified, used for update summary
  isStale     Boolean     @default(false)
  // populated by solver; current shape:
  // {"totalMinutes":1127,"productiveMinutes":758,"deadrunMinutes":47,"totalKm":439.2,"productiveKm":439.2,"deadrunKm":0}
  summary     Json?
  // { locked?: true }
  constraints Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  vehiclePlan   VehiclePlan     @relation(fields: [vehiclePlanId], references: [id], onDelete: Cascade)
  branch        Branch?         @relation("BranchVehicleBlocks", fields: [branchId], references: [id])
  depot         TransitLocality @relation(fields: [depotId], references: [id])
  blockTrips    BlockTrip[]
  blockDeadruns BlockDeadrun[]

  @@unique([vehiclePlanId, blockNumber])
  @@map("transit_vehicle_blocks")
}

model LineGroup {
  id        String   @id @default(uuid())
  name      String
  branchId  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch?         @relation("BranchLineGroups", fields: [branchId], references: [id])
  lines  LineGroupLine[]

  @@map("transit_line_groups")
}

model LineGroupLine {
  lineGroupId String
  lineId      String

  lineGroup LineGroup   @relation(fields: [lineGroupId], references: [id], onDelete: Cascade)
  line      TransitLine @relation(fields: [lineId], references: [id])

  @@id([lineGroupId, lineId])
  @@map("transit_line_group_lines")
}

model BlockTrip {
  id             String   @id @default(uuid())
  vehicleBlockId String
  tripId         String
  sequence       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicleBlock VehicleBlock @relation(fields: [vehicleBlockId], references: [id], onDelete: Cascade)
  trip         TransitTrip  @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([vehicleBlockId, sequence])
  @@map("transit_block_trips")
}

model BlockDeadrun {
  id                    String      @id @default(uuid())
  vehicleBlockId        String
  type                  DeadrunType
  originLocalityId      String
  destinationLocalityId String
  departureMinutes      Int
  arrivalMinutes        Int
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  vehicleBlock        VehicleBlock    @relation(fields: [vehicleBlockId], references: [id], onDelete: Cascade)
  originLocality      TransitLocality @relation("DeadrunOrigin", fields: [originLocalityId], references: [id])
  destinationLocality TransitLocality @relation("DeadrunDestination", fields: [destinationLocalityId], references: [id])

  @@map("transit_block_deadruns")
}
