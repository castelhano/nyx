{
  "name": "@nyx/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --watch ../../packages/schemas --watch ../../packages/types",
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:push": "prisma db push && prisma generate",
    "db:generate": "prisma generate",
    "db:seed": "ts-node -P tsconfig.seed.json -r tsconfig-paths/register prisma/seed.ts"
  },
  "prisma": {
    "seed": "pnpm db:seed"
  },
  "dependencies": {
    "@casl/ability": "^7.0.0",
    "@libsql/client": "^0.17.3",
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.23",
    "@nyx/schemas": "workspace:*",
    "@nyx/types": "workspace:*",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "@types/passport-jwt": "^4.0.1",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.4",
    "prisma": "^7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
