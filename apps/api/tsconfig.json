{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "ignoreDeprecations": "6.0",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "@nyx/schemas": ["../../packages/schemas/index.ts"],
      "@nyx/schemas/*": ["../../packages/schemas/*"],
      "@nyx/types": ["../../packages/types/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/schemas/**/*", "../../packages/types/**/*"],
  "exclude": ["node_modules"]
}
